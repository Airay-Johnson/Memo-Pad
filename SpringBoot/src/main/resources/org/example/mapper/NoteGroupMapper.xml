<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.NoteGroupMapper">

    <resultMap id="groupMap" type="org.example.entity.NoteGroup">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>

    <select id="selectAll" resultMap="groupMap">
        select * from note_group where user_id=#{userId} order by id
    </select>

    <insert id="insert" parameterType="org.example.entity.NoteGroup">
        insert into note_group(user_id, name) values(#{userId}, #{name})
    </insert>

    <delete id="deleteGroup">
        delete from note_group where id=#{id} and user_id=#{userId}
    </delete>

</mapper>
